    <visual>
      <origin
        xyz="0. 0.016 0.027"
        rpy="0. 0. -1.570796" />
      <geometry>
        <mesh
          filename="package://susgrip_2f_description/meshes/susgrip_2f_full/SUS_2F_Pad_L.obj" />
      </geometry>
