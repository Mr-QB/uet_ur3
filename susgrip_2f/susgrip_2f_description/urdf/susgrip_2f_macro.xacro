    <child
      link="${prefix}sus2f_pad_l_link" />
    <axis
      xyz="0 1 0" />
  </joint>

<!-- *************************** passive pad l link ************************************* -->

  <link name="${prefix}sus2f_passive_pad_l_link">
    <inertial>
      <origin
        xyz="0. 0. 0."
        rpy="0. 0. 0." />
      <mass value="0.01" />
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001" />
    </inertial>
    <visual>
      <origin
        xyz="0. -0.016 0.027"
        rpy="0. 0. 1.570796" />
      <geometry>
        <mesh
          filename="package://susgrip_2f_description/meshes/susgrip_2f_full/SUS_2F_Passive_Link_L.obj" />
      </geometry>
      <material
        name="color_pad">
      </material>
    </visual>
    <!-- No collision -->
  </link>

  <joint
    name="${prefix}passive_pad_inner_l_joint"
    type="continuous">
    <mimic joint="${prefix}gripper_joint" multiplier="19.264" offset="-1.218957"/>
    <limit effort="100.0" velocity="0.5"/>
    <origin
      xyz="0. 0. -0.027"
      rpy="0. 0. 0." />
    <parent
      link="${prefix}sus2f_inner_l_link" />
    <child
      link="${prefix}sus2f_passive_pad_l_link" />
    <axis
      xyz="0 1 0" />
  </joint>

<!-- ************************************************************************
*************************** right slide *************************************
***************************************************************************** -->

  <link name="${prefix}sus2f_slider_r_link">
    <inertial>
      <origin
        xyz="0. 0. 0."
        rpy="0. 0. 0." />
      <mass value="0.01" />
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001" />
