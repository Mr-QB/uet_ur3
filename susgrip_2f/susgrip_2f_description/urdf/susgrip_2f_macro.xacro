    <mimic joint="${prefix}gripper_joint" multiplier="9.632" offset="-0.609479"/>
    <origin
      xyz="0.0 0. 0.054"
      rpy="0. 0. 0." />
    <parent
      link="${prefix}sus2f_outer_l_link" />
    <child
      link="${prefix}sus2f_finger_l_link" />
    <axis
      xyz="0 1 0" />
  </joint>

<!-- *************************** inner l link ************************************* -->

  <link name="${prefix}sus2f_inner_l_link">
    <inertial>
      <origin
        xyz="0. 0. 0."
        rpy="0. 0. 0." />
      <mass value="0.01" />
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001" />
