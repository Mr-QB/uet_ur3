    type="continuous">
    <mimic joint="${prefix}gripper_joint" multiplier="9.632" offset="-0.609479"/>
    <origin
      xyz="0.0 0. 0.054"
      rpy="0. 0. 3.141592" />
    <parent
      link="${prefix}sus2f_outer_r_link" />
    <child
      link="${prefix}sus2f_finger_r_link" />
    <axis
      xyz="0 1 0" />
  </joint>

<!-- *************************** inner r link ************************************* -->

  <link name="${prefix}sus2f_inner_r_link">
    <inertial>
      <origin
        xyz="0. 0. 0."
        rpy="0. 0. 0." />
      <mass value="0.01" />
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001" />
    </inertial>
    <visual>
      <origin
        xyz="0.04 0. -0.097"
        rpy="0. 0. 3.141592" />
      <geometry>
        <mesh
          filename="package://susgrip_2f_description/meshes/susgrip_2f_full/SUS_2F_Inner_R.obj" />
      </geometry>
      <material
        name="color_link">
      </material>
    </visual>
    <!-- No collision -->
  </link>
  <joint
    name="${prefix}finger_inner_r_joint"
    type="continuous">
    <mimic joint="${prefix}gripper_joint" multiplier="9.632" offset="-0.609479"/>
    <origin
      xyz="0.013 0. 0."
      rpy="0. 0. 3.141592" />
    <parent
      link="${prefix}sus2f_finger_r_link" />
    <child
      link="${prefix}sus2f_inner_r_link" />
    <axis
      xyz="0 1 0" />
  </joint>

<!-- *************************** pad r link ************************************* -->

  <link name="${prefix}sus2f_pad_r_link">
    <inertial>
      <origin
        xyz="0. 0. 0."
        rpy="0. 0. 0." />
      <mass value="0.01" />
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001" />
    </inertial>
    <visual>
      <origin
        xyz="0. -0.016 0.027"
        rpy="0. 0. 1.570796" />
      <geometry>
        <mesh
          filename="package://susgrip_2f_description/meshes/susgrip_2f_full/SUS_2F_Pad_R.obj" />
      </geometry>
      <material
        name="color_pad">
      </material>
    </visual>
    <!-- No collision -->
  </link>

  <joint
