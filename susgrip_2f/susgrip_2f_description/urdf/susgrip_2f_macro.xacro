      <origin
        xyz="0. 0. 0."
        rpy="0. 0. 0." />
      <mass value="0.01" />
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001" />
    </inertial>
    <visual>
      <origin
        xyz="-0.053 0. -0.043"
        rpy="0. 0. 3.141593" />
      <geometry>
        <mesh
          filename="package://susgrip_2f_description/meshes/susgrip_2f_full/SUS_2F_Outer_R.obj" />
      </geometry>
      <material
        name="color_link">
      </material>
    </visual>
    <!-- No collision -->
  </link>
  <joint
    name="${prefix}slider_outer_r_joint"
    type="continuous">
    <mimic joint="${prefix}gripper_joint" multiplier="9.632" offset="-0.609479"/>
    <limit effort="100.0" lower="-1.5" upper="1.5" velocity="0.5"/>
    <origin
      xyz="0.053 0. 0.043"
      rpy="0. 0. 0." />
    <parent
      link="${prefix}sus2f_slider_r_link" />
    <child
      link="${prefix}sus2f_outer_r_link" />
    <axis
      xyz="0 1 0" />
  </joint>

<!-- *************************** finger r link ************************************* -->

  <link name="${prefix}sus2f_finger_r_link">
    <inertial>
      <origin
        xyz="0 0 0"
        rpy="0 0 0"/>
      <mass value="0.01" />
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001" />
    </inertial>
    <visual>
      <origin
        xyz="0.053 0 -0.097"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://susgrip_2f_description/meshes/susgrip_2f_full/SUS_2F_Finger_R.obj" />
      </geometry>
      <material
        name="color_finger">
      </material>
    </visual>
    <!-- No collision -->
  </link>
  <joint
