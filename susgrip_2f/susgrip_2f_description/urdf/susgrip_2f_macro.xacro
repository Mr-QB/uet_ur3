    <mimic joint="${prefix}gripper_joint" multiplier="-9.632" offset="0.609479"/>
    <origin
      xyz="0.013 0. 0."
      rpy="0. 0. 0." />
    <parent
      link="${prefix}sus2f_finger_l_link" />
    <child
      link="${prefix}sus2f_inner_l_link" />
    <axis
      xyz="0 1 0" />
  </joint>

<!-- *************************** pad l link ************************************* -->

  <link name="${prefix}sus2f_pad_l_link">
    <inertial>
      <origin
        xyz="0. 0. 0."
