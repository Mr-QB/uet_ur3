    type="continuous">
    <mimic joint="${prefix}gripper_joint" multiplier="-19.264" offset="1.218957"/>
    <limit effort="100.0" velocity="0.5"/>
    <origin
      xyz="0. 0. -0.027"
      rpy="0. 0. 0." />
    <parent
      link="${prefix}sus2f_inner_r_link" />
    <child
      link="${prefix}sus2f_passive_pad_r_link" />
    <axis
      xyz="0 1 0" />
  </joint>

  <xacro:if value="${sim_gazebo}">
    <ros2_control name="SusgripGazeboSystem" type="system">
      <hardware>
        <plugin>gazebo_ros2_control/GazeboSystem</plugin>
      </hardware>
      <joint name="${prefix}gripper_joint">
        <command_interface name="position"/>
        <command_interface name="velocity"/>
        <command_interface name="effort"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>

      <xacro:macro name="mimic_joint_gazebo" params="name multiplier offset">
        <joint name="${name}">
          <command_interface name="position"/>
          <state_interface name="position"/>
          <state_interface name="velocity"/>
          <state_interface name="effort"/>
        </joint>
      </xacro:macro>

      <xacro:mimic_joint_gazebo name="${prefix}base_slider_l_joint" multiplier="0.036" offset="0.000753"/>
      <xacro:mimic_joint_gazebo name="${prefix}slider_outer_l_joint" multiplier="-9.632" offset="0.609479"/>
      <xacro:mimic_joint_gazebo name="${prefix}finger_outer_l_joint" multiplier="9.632" offset="-0.609479"/>
      <xacro:mimic_joint_gazebo name="${prefix}pad_inner_l_joint" multiplier="19.264" offset="-1.218957"/>
      <xacro:mimic_joint_gazebo name="${prefix}passive_pad_inner_l_joint" multiplier="19.264" offset="-1.218957"/>
      <xacro:mimic_joint_gazebo name="${prefix}finger_inner_l_joint" multiplier="-9.632" offset="0.609479"/>

      <xacro:mimic_joint_gazebo name="${prefix}base_slider_r_joint" multiplier="0.036" offset="0.000753"/>
      <xacro:mimic_joint_gazebo name="${prefix}slider_outer_r_joint" multiplier="-9.632" offset="0.609479"/>
      <xacro:mimic_joint_gazebo name="${prefix}finger_outer_r_joint" multiplier="9.632" offset="-0.609479"/>
      <xacro:mimic_joint_gazebo name="${prefix}pad_inner_r_joint" multiplier="-19.264" offset="1.218957"/>
      <xacro:mimic_joint_gazebo name="${prefix}passive_pad_inner_r_joint" multiplier="-19.264" offset="1.218957"/>
      <xacro:mimic_joint_gazebo name="${prefix}finger_inner_r_joint" multiplier="9.632" offset="-0.609479"/>
    </ros2_control>

    <xacro:if value="${parent == 'world'}">
      <gazebo reference="world"> </gazebo>
      <gazebo>
        <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
          <parameters>${simulation_controllers}</parameters>
          <robot_param>robot_description</robot_param>
          <robot_param_node>robot_state_publisher_gazebo</robot_param_node>
          <ros>
            <namespace>/</namespace>
          </ros>
        </plugin>
      </gazebo>
    </xacro:if>
  </xacro:if>



  </xacro:macro>
</robot>