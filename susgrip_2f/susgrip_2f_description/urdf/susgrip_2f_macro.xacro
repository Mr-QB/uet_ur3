<robot xmlns:xacro="http://wiki.ros.org/xacro">
  <xacro:macro name="susgrip_2f" params="prefix parent *origin sim_gazebo:=false simulation_controllers:=''">

  <material name="color_base">
    <color rgba="0.423529 0.494118 0.882353 1.0" />
  </material>
  <material name="color_finger">
    <color rgba="0.572549 0.72549 0.890196 1.0" />
  </material>
  <material name="color_pad">
    <color rgba="1.0 0.768627 0.643137 1.0" />
  </material>
  <material name="color_link">
    <color rgba="0.776471 0.533333 0.921569 1.0" />
  </material>
  <material name="color_slider">
    <color rgba="0.984314 0.635294 0.815686 1.0" />
  </material>
  <material name="color_A1">
    <color rgba="0.627450 0.866666 1 1" />
  </material>
  <material name="color_A2">
    <color rgba="0.129411 0.172549 0.407843 1" />
  </material>
  
<!-- *************************** base link ************************************* -->

    <!-- Base joint to connect to robot -->
    <joint name="${prefix}susgrip_base_joint" type="fixed">
      <xacro:insert_block name="origin" />
      <parent link="${parent}" />
      <child link="${prefix}sus2f_base_link" />
    </joint>


    <link name="${prefix}gripper_link">
      <inertial>
        <mass value="0.01" />
        <origin xyz="0 0 0" rpy="0 0 0" />
        <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001" />
      </inertial>
    </link>


    <joint name="${prefix}gripper_joint" type="prismatic">
      <limit effort="100.0" lower="0.0" upper="0.130" velocity="0.1" />
      <origin xyz="0 0 0" rpy="0 0 0" />
      <parent link="${prefix}sus2f_base_link" />
      <child link="${prefix}gripper_link" />
      <axis xyz="0 0 1" />
    </joint>

  <link
    name="${prefix}sus2f_base_link">
    <inertial>
      <origin
        xyz="0. 0. 0.06"
        rpy="-1.570796 0. 0." />
      <mass value="0.148118292371017" />
      <inertia ixx="0.000127380225676606" ixy="2.45032695761012e-06" ixz="0.0" iyy="0.000134249396452626" iyz="0.0" izz="0.000126530130055728" />
    </inertial>
    <visual>
      <origin
        xyz="0. 0. 0.06"
        rpy="-1.570796 0. 0." />
      <geometry>
        <mesh
          filename="package://susgrip_2f_description/meshes/susgrip_2f_full/SUS_2F_Base.STL"
          />
      </geometry>
      <material
        name="color_base">
      </material>
    </visual>
    
    <visual>
      <origin
        xyz="-0.041 0.0125 0.02"
        rpy="1.570796 0 3.141592" />
      <geometry>
        <mesh
          filename="package://susgrip_2f_description/meshes/susgrip_2f_full/SUS_2F_ShaftPhi_0.STL"
          />
      </geometry>
      <material
        name="color_base">
      </material>
    </visual>
    <visual>
      <origin
        xyz="-0.041 -0.0125 0.02"
        rpy="1.570796 0 3.141592" />
      <geometry>
        <mesh
          filename="package://susgrip_2f_description/meshes/susgrip_2f_full/SUS_2F_ShaftPhi_1.STL"
          />
      </geometry>
      <material
        name="color_base">
      </material>
    </visual>
    <visual>
      <origin
        xyz="0.041 0.0125 0.02"
        rpy="1.570796 0 3.141592" />
      <geometry>
        <mesh
          filename="package://susgrip_2f_description/meshes/susgrip_2f_full/SUS_2F_ShaftPhi_2.STL"
          />
      </geometry>
      <material
        name="color_base">
      </material>
    </visual>
    <visual>
      <origin
        xyz="0.041 -0.0125 0.02"
        rpy="1.570796 0 3.141592" />
      <geometry>
        <mesh
          filename="package://susgrip_2f_description/meshes/susgrip_2f_full/SUS_2F_ShaftPhi_3.STL"
          />
      </geometry>
      <material
        name="color_base">
      </material>
    </visual>

    <visual>
      <origin
        xyz="0.0184 0.027 0.07"
        rpy="0 3.141592 3.141592" />
      <geometry>
        <mesh
          filename="package://susgrip_2f_description/meshes/susgrip_2f_full/SUS_2F_A1.obj"
          />
      </geometry>
      <material
        name="color_A1">
      </material>
    </visual>
    <visual>
      <origin
        xyz="-0.0184 0.027 0.07"
        rpy="0 3.141592 3.141592" />
      <geometry>
        <mesh
          filename="package://susgrip_2f_description/meshes/susgrip_2f_full/SUS_2F_A2.obj"
          />
      </geometry>
      <material
        name="color_A2">
      </material>
    </visual>
    <visual>
      <origin
        xyz="-0.0184 -0.027 0.07"
        rpy="0 3.141592 0" />
      <geometry>
        <mesh
          filename="package://susgrip_2f_description/meshes/susgrip_2f_full/SUS_2F_A1.obj"
          />
      </geometry>
      <material
        name="color_A1">
      </material>
    </visual>
    <visual>
      <origin
        xyz="0.0184 -0.027 0.07"
        rpy="0 3.141592 0" />
      <geometry>
        <mesh
          filename="package://susgrip_2f_description/meshes/susgrip_2f_full/SUS_2F_A2.obj"
          />
      </geometry>
      <material
        name="color_A2">
      </material>
    </visual>

    <collision>
      <origin
        xyz="0. 0. 0.06"
        rpy="-1.570796 0. 0." />
      <geometry>
        <cylinder radius="0.04" length="0.12" />
      </geometry>
    </collision>
  </link>

<!-- *************************** slider l link ************************************* -->

  <link name="${prefix}sus2f_slider_l_link">
    <inertial>
      <origin
        xyz="0. 0. 0."
        rpy="0. 0. 0." />
      <mass value="0.01" />
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001" />
    </inertial>
    <visual>
      <origin
        xyz="0. 0. 0."
        rpy="0. 0. 0." />
      <geometry>
        <mesh
          filename="package://susgrip_2f_description/meshes/susgrip_2f_full/SUS_2F_Slider_L.obj" />
      </geometry>
      <material
        name="">
        <color rgba="0.129411 0.172549 0.407843 1" />
      </material>
    </visual>
    <!-- No collision -->
  </link>
  <joint
    name="${prefix}base_slider_l_joint"
    type="prismatic">
    <mimic joint="${prefix}gripper_joint" multiplier="0.036" offset="0.000753"/>
    <limit effort="100.0" lower="0.0" upper="0.015" velocity="0.5"/>
    <origin
      xyz="0. 0. 0."
      rpy="0. 0. 0." />
    <parent
      link="${prefix}sus2f_base_link" />
    <child
      link="${prefix}sus2f_slider_l_link" />
    <axis
      xyz="0 0 1" />
  </joint>

<!-- *************************** outer l link ************************************* -->

  <link name="${prefix}sus2f_outer_l_link">
    <inertial>
      <origin
        xyz="0. 0. 0."
        rpy="0. 0. 0." />
      <mass value="0.01" />
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001" />
