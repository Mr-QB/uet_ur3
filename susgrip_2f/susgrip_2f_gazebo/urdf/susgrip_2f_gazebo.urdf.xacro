<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:macro name="susgrip_2f_gazebo" params="prefix parent *origin">

        <xacro:property name="gripper_mass" value="1.0" />
        <xacro:property name="finger_mass" value="0.1" />
        <xacro:property name="joint_damping" value="50.0" />
        <xacro:property name="joint_friction" value="1.0" />
        <xacro:property name="joint_effort" value="100.0" />
        <xacro:property name="joint_velocity" value="0.05" />
        <xacro:property name="joint_limit_upper" value="0.065" />

        <material name="${prefix}color_base">
            <color rgba="0.423529 0.494118 0.882353 1.0" />
        </material>
        <material name="${prefix}color_finger">
            <color rgba="0.572549 0.72549 0.890196 1.0" />
        </material>

        <!-- Base connection joint -->
        <joint name="${prefix}susgrip_base_joint" type="fixed">
            <xacro:insert_block name="origin" />
            <parent link="${parent}" />
            <child link="${prefix}gripper_body" />
        </joint>

        <!-- Gripper Body -->
        <link name="${prefix}gripper_body">
            <visual>
                <origin xyz="0 0 0" rpy="0 0 0" />
                <geometry>
                    <mesh filename="package://susgrip_2f_description/meshes/susgrip_2f_simple/2F_MainBody.STL" />
                </geometry>
                <material name="${prefix}color_base" />
            </visual>
            <collision>
                <origin xyz="0 0 0" rpy="0 0 0" />
                <geometry>
                    <mesh filename="package://susgrip_2f_description/meshes/susgrip_2f_simple/2F_MainBody.STL" />
                </geometry>
            </collision>
            <inertial>
                <mass value="${gripper_mass}" />
                <origin xyz="0.0 0.002 0.0615" rpy="0 0 0" />
                <inertia 
                    ixx="0.006304" ixy="-0.000005" ixz="0.000018" 
                    iyy="0.007313" iyz="0.000199" 
                    izz="0.001895" />
            </inertial>
        </link>

        <!-- Gazebo tag for body -->
        <gazebo reference="${prefix}gripper_body">
            <self_collide>false</self_collide>
            <mu1>2.0</mu1>
            <mu2>2.0</mu2>
            <material>Gazebo/SkyBlue</material>
        </gazebo>

        <!-- Left Finger -->
        <link name="${prefix}finger_left">
            <visual>
                <origin xyz="0 0 0" rpy="0 0 0" />
                <geometry>
                    <mesh filename="package://susgrip_2f_description/meshes/susgrip_2f_simple/FingerTip.STL" />
                </geometry>
                <material name="${prefix}color_finger" />
            </visual>
            <collision>
                <origin xyz="0 0 0" rpy="0 0 0" />
                <geometry>
                    <mesh filename="package://susgrip_2f_description/meshes/susgrip_2f_simple/FingerTip.STL" />
                </geometry>
            </collision>
            <inertial>
                <origin xyz="0 0 0" rpy="0 0 0" />
                <mass value="${finger_mass}" />
                <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001" />
            </inertial>
        </link>

        <gazebo reference="${prefix}finger_left">
            <self_collide>false</self_collide>
            <mu1>2.0</mu1>
            <mu2>2.0</mu2>
            <kp>1000000.0</kp>
            <kd>100.0</kd>
            <minDepth>0.002</minDepth>
            <maxVel>0.0</maxVel>
            <material>Gazebo/Blue</material>
        </gazebo>

        <!-- Right Finger -->
        <link name="${prefix}finger_right">
            <visual>
                <origin xyz="0 0 0" rpy="0 0 0" />
                <geometry>
                    <mesh filename="package://susgrip_2f_description/meshes/susgrip_2f_simple/FingerTip.STL" />
                </geometry>
                <material name="${prefix}color_finger" />
            </visual>
            <collision>
                <origin xyz="0 0 0" rpy="0 0 0" />
                <geometry>
                    <mesh filename="package://susgrip_2f_description/meshes/susgrip_2f_simple/FingerTip.STL" />
                </geometry>
            </collision>
            <inertial>
                <origin xyz="0 0 0" rpy="0 0 0" />
                <mass value="${finger_mass}" />
                <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001" />
            </inertial>
        </link>

        <gazebo reference="${prefix}finger_right">
            <self_collide>false</self_collide>
            <mu1>2.0</mu1>
            <mu2>2.0</mu2>
            <kp>1000000.0</kp>
            <kd>100.0</kd>
            <minDepth>0.002</minDepth>
            <maxVel>0.0</maxVel>
            <material>Gazebo/Blue</material>
        </gazebo>

        <!-- Prismatic joint for left finger (ACTIVE JOINT) -->
        <joint name="${prefix}gripper_joint" type="prismatic">
            <parent link="${prefix}gripper_body" />
            <child link="${prefix}finger_left" />
            <origin xyz="0.0135 0.0 0.112" rpy="0 0 3.14159265" />
            <axis xyz="-1 0 0" />
            <limit lower="0.0" upper="${joint_limit_upper}" effort="${joint_effort}" velocity="${joint_velocity}" />
            <dynamics damping="${joint_damping}" friction="${joint_friction}" />
        </joint>

        <!-- Prismatic joint for right finger (MIMIC ONLY - NO COMMAND INTERFACE) -->
        <joint name="${prefix}gripper_joint_mimic" type="prismatic">
            <parent link="${prefix}gripper_body" />
            <child link="${prefix}finger_right" />
            <origin xyz="-0.0135 0.0 0.112" rpy="0 0 0" />
            <axis xyz="-1 0 0" />
            <limit lower="0.0" upper="${joint_limit_upper}" effort="${joint_effort}" velocity="${joint_velocity}" />
            <mimic joint="${prefix}gripper_joint" multiplier="1.0" offset="0" />
            <dynamics damping="${joint_damping}" friction="${joint_friction}" />
        </joint>


        <!-- moveit to ros2 control of robot -->
        <!-- <xacro:if value="${'$(arg use_gripper)' == 'susgrip_gazebo'}">
            <joint name="${prefix}gripper_joint">
                <command_interface name="position" />
                <command_interface name="velocity" />
                <command_interface name="effort" />
                <state_interface name="position">
                    <param name="initial_value">0.0</param>
                </state_interface>
                <state_interface name="velocity" />
                <state_interface name="effort" />
            </joint>
            <joint name="${prefix}gripper_joint_mimic">
                <state_interface name="position" />
                <state_interface name="velocity" />
                <state_interface name="effort" />
            </joint>
        </xacro:if> -->
    </xacro:macro>

</robot>